0F36Eh 4F                               LD        C,A            ; All in all compute E = E - A
0F36Fh 7B                               LD        A,E
0F370h 91                               SUB       C
0F371h 5F                               LD        E,A
0F372h 79                               LD        A,C
0F373h C1                               POP       BC
0F374h C9                               RET       
