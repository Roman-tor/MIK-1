0F375h                                                           ;------------------------------------------------------------------------------
0F375h                                                           ;---
0F375h                                                           ;--- String subroutines
0F375h                                                           ;---
0F375h                                                           ;------------------------------------------------------------------------------
0F375h                                            
0F375h                                                           ;
0F375h                                                           ; Send a string to the serial line, HL contains the pointer to the string:
0F375h                                                           ;
0F375h F5         PUTS:                 PUSH      AF
0F376h E5                               PUSH      HL
0F377h 7E         PUTS_LOOP:            LD        A,(HL)
0F378h FE00                             CP        EOS            ; End of string reached?
0F37Ah 2806                             JR        Z,PUTS_END     ; Yes
0F37Ch CDC9F0                           CALL      PUTC
0F37Fh 23                               INC       HL             ; Increment character pointer
0F380h 18F5                             JR        PUTS_LOOP      ; Transmit next character
0F382h E1         PUTS_END:             POP       HL
0F383h F1                               POP       AF
0F384h C9                               RET       
0F385h                                                           ;
0F385h                                                           ; Get a word (16 bit) in hexadecimal notation. The result is returned in HL.
0F385h                                                           ; Since the routines get_byte and therefore get_nibble are called, only valid
0F385h                                                           ; characters (0-9a-f) are accepted.
0F385h                                                           ;
0F385h F5         GET_WORD:             PUSH      AF
0F386h CD90F3                           CALL      GET_BYTE       ; Get the upper byte
0F389h 67                               LD        H,A
0F38Ah CD90F3                           CALL      GET_BYTE       ; Get the lower byte
0F38Dh 6F                               LD        L,A
0F38Eh F1                               POP       AF
0F38Fh C9                               RET       
0F390h                                                           ;
0F390h                                                           ; Get a byte in hexadecimal notation. The result is returned in A. Since
0F390h                                                           ; the routine get_nibble is used only valid characters are accepted - the 
0F390h                                                           ; input routine only accepts characters 0-9a-f.
0F390h                                                           ;
0F390h C5         GET_BYTE:             PUSH      BC             ; Save contents of B (and C)
0F391h CDA3F3                           CALL      GET_NIBBLE     ; Get upper nibble
0F394h CB07                             RLC       A
0F396h CB07                             RLC       A
0F398h CB07                             RLC       A
0F39Ah CB07                             RLC       A
0F39Ch 47                               LD        B,A            ; Save upper four bits
0F39Dh CDA3F3                           CALL      GET_NIBBLE     ; Get lower nibble
0F3A0h B0                               OR        B              ; Combine both nibbles
0F3A1h C1                               POP       BC             ; Restore B (and C)
0F3A2h C9                               RET       
0F3A3h                                                           ;
0F3A3h                                                           ; Get a hexadecimal digit from the serial line. This routine blocks until
0F3A3h                                                           ; a valid character (0-9a-f) has been entered. A valid digit will be echoed
0F3A3h                                                           ; to the serial line interface. The lower 4 bits of A contain the value of 
0F3A3h                                                           ; that particular digit.
0F3A3h                                                           ;
0F3A3h CDD3F0     GET_NIBBLE:           CALL      GETC           ; Read a character
0F3A6h CDC9F3                           CALL      TO_UPPER       ; Convert to upper case
0F3A9h CDB5F3                           CALL      IS_HEX         ; Was it a hex digit?
0F3ACh 30F5                             JR        NC,GET_NIBBLE  ; No, get another character
0F3AEh CDD2F3                           CALL      NIBBLE2VAL     ; Convert nibble to value
0F3B1h CDDDF3                           CALL      PRINT_NIBBLE
0F3B4h C9                               RET       
0F3B5h                                                           ;
0F3B5h                                                           ; is_hex checks a character stored in A for being a valid hexadecimal digit.
0F3B5h                                                           ; A valid hexadecimal digit is denoted by a set C flag.
0F3B5h                                                           ;
0F3B5h FE47       IS_HEX:               CP        'G'            ; Greater than 'F'?
0F3B7h D0                               RET       NC             ; Yes
0F3B8h FE30                             CP        '0'            ; Less than '0'?
0F3BAh 3002                             JR        NC,IS_HEX_1    ; No, continue
0F3BCh 3F                               CCF                      ; Complement carry (i.e. clear it)
0F3BDh C9                               RET       
0F3BEh FE3A       IS_HEX_1:             CP        ':'            ; Less or equal '9*?
0F3C0h D8                               RET       C              ; Yes
0F3C1h FE41                             CP        'A'            ; Less than 'A'?
0F3C3h 3002                             JR        NC,IS_HEX_2    ; No, continue
0F3C5h 3F                               CCF                      ; Yes - clear carry and return
0F3C6h C9                               RET       
0F3C7h 37         IS_HEX_2:             SCF                      ; Set carry
0F3C8h C9                               RET       
0F3C9h                                                           ;
0F3C9h                                                           ; Convert a single character contained in A to upper case:
0F3C9h                                                           ;
0F3C9h FE61       TO_UPPER:             CP        'a'            ; Nothing to do if not lower case
0F3CBh D8                               RET       C
0F3CCh FE7B                             CP        '{'            ; > 'z'?
0F3CEh D0                               RET       NC             ; Nothing to do, either
0F3CFh E65F                             AND       #5F            ; Convert to upper case
0F3D1h C9                               RET       
0F3D2h                                                           ;
0F3D2h                                                           ; Expects a hexadecimal digit (upper case!) in A and returns the
0F3D2h                                                           ; corresponding value in A.
0F3D2h                                                           ;
0F3D2h FE3A       NIBBLE2VAL:           CP        ':'            ; Is it a digit (less or equal '9')?
0F3D4h 3802                             JR        C,NIBBLE2VAL_1 ; Yes
0F3D6h D607                             SUB       7              ; Adjust for A-F
0F3D8h D630       NIBBLE2VAL_1:         SUB       '0'            ; Fold back to 0..15
0F3DAh E60F                             AND       #F             ; Only return lower 4 bits
0F3DCh C9                               RET       
0F3DDh                                                           ;
0F3DDh                                                           ; Print_nibble prints a single hex nibble which is contained in the lower 
0F3DDh                                                           ; four bits of A:
0F3DDh                                                           ;
0F3DDh F5         PRINT_NIBBLE:         PUSH      AF             ; We won't destroy the contents of A
0F3DEh E60F                             AND       #F             ; Just in case...
0F3E0h C630                             ADD       A,'0'          ; If we have a digit we are done here.
0F3E2h FE3A                             CP        ':'            ; Is the result > 9?
0F3E4h 3802                             JR        C,PRINT_NIBBLE_1
0F3E6h C607                             ADD       A,7            ; Take care of A-F
0F3E8h CDC9F0     PRINT_NIBBLE_1:       CALL      PUTC           ; Print the nibble and
0F3EBh F1                               POP       AF             ; restore the original value of A
0F3ECh C9                               RET       
0F3EDh                                                           ;
0F3EDh                                                           ; Send a CR/LF pair:
0F3EDh                                                           ;
0F3EDh F5         CRLF:                 PUSH      AF
0F3EEh 3E0D                             LD        A,CR
0F3F0h CDC9F0                           CALL      PUTC
0F3F3h 3E0A                             LD        A,LF
0F3F5h CDC9F0                           CALL      PUTC
0F3F8h F1                               POP       AF
0F3F9h C9                               RET       
0F3FAh                                                           ;
0F3FAh                                                           ; Print_word prints the four hex digits of a word to the serial line. The 
0F3FAh                                                           ; word is expected to be in HL.
0F3FAh                                                           ;
0F3FAh E5         PRINT_WORD:           PUSH      HL
0F3FBh F5                               PUSH      AF
0F3FCh 7C                               LD        A,H
0F3FDh CD07F4                           CALL      PRINT_BYTE
0F400h 7D                               LD        A,L
0F401h CD07F4                           CALL      PRINT_BYTE
0F404h F1                               POP       AF
0F405h E1                               POP       HL
0F406h C9                               RET       
0F407h                                                           ;
0F407h                                                           ; Print_byte prints a single byte in hexadecimal notation to the serial line.
0F407h                                                           ; The byte to be printed is expected to be in A.
0F407h                                                           ;
0F407h F5         PRINT_BYTE:           PUSH      AF             ; Save the contents of the registers
0F408h C5                               PUSH      BC
0F409h 47                               LD        B,A
0F40Ah 0F                               RRCA      
0F40Bh 0F                               RRCA      
0F40Ch 0F                               RRCA      
0F40Dh 0F                               RRCA      
0F40Eh CDDDF3                           CALL      PRINT_NIBBLE   ; Print high nibble
0F411h 78                               LD        A,B
0F412h CDDDF3                           CALL      PRINT_NIBBLE   ; Print low nibble
0F415h C1                               POP       BC             ; Restore original register contents
0F416h F1                               POP       AF
0F417h C9                               RET       
