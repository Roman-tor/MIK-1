0F31Ch A7                               AND       A              ; Reset flag C
0F31Dh 01FFFE                           LD        BC,LOADER_RAM+#FF;ld BC, end_iLoad ; koniec progr. iLOAD, oblicza kompilator
0F320h ED42                             SBC       HL,BC
