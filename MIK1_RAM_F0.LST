0F361h CDEDF3     IH_LOAD_EXIT:         CALL      CRLF
0F364h CD0FF1                           CALL      FLUSH_TX
0F367h 60                               LD        H,B            ; HL = BC
0F368h 69                               LD        L,C
0F369h C1                               POP       BC             ; Restore registers
